FROM registry.redhat.io/rhel10/rhel-bootc:latest@sha256:e81f6b7e6dd197d3f2a82c88cbde40e76942611dd09985f9840802b5abb09ae3

COPY ./bootc/rhel10/etc /etc/
COPY ./bootc/rhel10/usr /usr/
RUN <<EOF
  systemctl disable kdump
  systemctl mask rpm-ostree-countme.time
  dnf install -y rhc dnf-plugins-core vim zsh tmux systemd-resolved tuned
  dnf clean all
  systemctl enable systemd-resolved.service
EOF
