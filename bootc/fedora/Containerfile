FROM quay.io/fedora/fedora-bootc:latest@sha256:1e87ded94330b06d317434fc791ee10b7c817d42c67531d030c4e7a37a4b4731

COPY ./bootc/fedora/etc /etc/
RUN <<EOF
  systemctl mask rpm-ostree-countme.time
  update-ca-trust
  dnf -y install dnf5-plugins vim tmux tuned
  dnf clean all
  echo 'L /etc/resolv.conf - - - - /run/systemd/resolve/stub-resolv.conf' > /usr/lib/tmpfiles.d/resolv-conf.conf
EOF
