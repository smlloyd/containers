FROM quay.io/fedora/fedora-bootc:latest@sha256:a0fc5a3b2d81932eccd0f3ae4290727914c530c800fe468423344ce57248ae53

COPY ./bootc/fedora/etc /etc/
RUN <<EOF
  systemctl mask rpm-ostree-countme.time
  update-ca-trust
  dnf -y install dnf5-plugins vim tmux tuned
  dnf clean all
  ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
EOF
