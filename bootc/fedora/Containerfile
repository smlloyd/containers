FROM quay.io/fedora/fedora-bootc:latest@sha256:4f23d1dc70a7ad2d78bb42a02c54c6dbf746c80b62d383db88311b980a22bd01

COPY ./bootc/fedora/etc /etc/
RUN <<EOF
   dnf -y install dnf5-plugins vim tmux tuned
   dnf config-manager addrepo --from-repofile=https://pkgs.tailscale.com/stable/fedora/tailscale.repo
   dnf install -y tailscale
   dnf clean all
   systemctl enable tailscaled
EOF
