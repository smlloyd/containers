FROM registry.redhat.io/rhel9/rhel-bootc:latest@sha256:9049d8e1a48a14b76ac422537bcca202b3ea9703c7cc2a53a68e71aa9f9b8f56

COPY ./bootc/rhel9/etc /etc/
RUN <<EOF
  systemctl disable kdump
  systemctl mask rpm-ostree-countme.time
  dnf install -y rhc dnf-plugins-core vim zsh tmux systemd-resolved tuned
  dnf clean all
  systemctl enable systemd-resolved.service
  echo 'L /etc/resolv.conf - - - - /run/systemd/resolve/stub-resolv.conf' > /usr/lib/tmpfiles.d/resolv-conf.conf
EOF
