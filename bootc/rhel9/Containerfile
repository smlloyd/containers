FROM registry.redhat.io/rhel9/rhel-bootc:latest@sha256:72134a80eba804cad38b597c26e917baaa5c419330162b9201b0e4be8ab9dbed

COPY ./bootc/rhel9/etc /etc/
RUN <<EOF
  systemctl disable kdump
  systemctl mask rpm-ostree-countme.time
  dnf install -y rhc dnf-plugins-core vim zsh tmux systemd-resolved tuned
  dnf clean all
  systemctl enable systemd-resolved.service
  ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
EOF
